# HAPI FHIR US Core Server - Environment variables
# Copy to .env and adjust as needed

# PostgreSQL password
POSTGRES_PASSWORD=admin

# PostgreSQL host port (default: 5433 to avoid conflict with host's 5432)
POSTGRES_PORT=5433

# FHIR server port (default: 8023)
FHIR_PORT=8023

# Terminology mode:
#   remote (default): Use tx.fhir.org for LOINC/SNOMED - no local upload needed
#   local: Use locally loaded terminology - run scripts/load-terminology.sh first
#
# For remote (tx.fhir.org) - default:
# SPRING_CONFIG_ADDITIONAL_LOCATION=file:///config/application.yaml
#
# For local terminology (no tx dependency):
# SPRING_CONFIG_ADDITIONAL_LOCATION=file:///config/application-local-terminology.yaml
